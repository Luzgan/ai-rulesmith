{
  "name": "ai-rulesmith",
  "version": "0.3.0",
  "description": "Compose AI agent context files from reusable markdown rules",
  "type": "module",
  "bin": {
    "ai-rulesmith": "./dist/bin/rulesmith.js",
    "rulesmith": "./dist/bin/rulesmith.js",
    "cb": "./dist/bin/rulesmith.js"
  },
  "files": [
    "dist/",
    "rules/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx bin/rulesmith.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "./scripts/release.sh"
  },
  "keywords": [
    "ai",
    "rules",
    "context",
    "claude",
    "cursor",
    "copilot",
    "markdown",
    "cli"
  ],
  "author": "Luzgan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luzgan/ai-rulesmith.git"
  },
  "homepage": "https://github.com/Luzgan/ai-rulesmith#readme",
  "bugs": {
    "url": "https://github.com/Luzgan/ai-rulesmith/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "openai": "^6.25.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
